#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Load environment variables from .env
if [ -f "$SCRIPT_DIR/.env" ]; then
    set -a
    source "$SCRIPT_DIR/.env"
    set +a
fi

API_KEY="${PTERO_API_KEY:-}"
PANEL_URL="${PTERO_PANEL_URL:-https://panel.azox.net}"

# Default server ID
DEFAULT_SERVER="${PTERO_DEFAULT_SERVER:-9323a5c9}"

# Available servers (non-sensitive)
SERVER_IDS=(
    "0ddde059:plugin testing"
    "e8337f4a:azox"
    "0128d99d:test server"
    "b03c2811:uriah server"
)

# Parse -s flag for server selection
SERVER="$DEFAULT_SERVER"
while getopts "s:" opt; do
    case $opt in
        s) SERVER="$OPTARG" ;;
    esac
done
shift $((OPTIND -1))

CMD="$1"

case "$CMD" in
    list)
        curl -s -H "Authorization: Bearer $API_KEY" \
            -H "Content-Type: application/json" \
            "$PANEL_URL/api/application/servers" | python3 -c "
import json,sys
data=json.load(sys.stdin)
for s in data['data']:
    a=s['attributes']
    print(f\"{a['id']:2} | {a['name']:20} | {a['identifier']}\")"
        ;;
    status)
        curl -s -H "Authorization: Bearer $API_KEY" \
            -H "Content-Type: application/json" \
            "$PANEL_URL/api/client/servers/$SERVER/resources" | python3 -c "
import json,sys
data=json.load(sys.stdin)
print(f\"State: {data['attributes']['current_state']}\")"
        ;;
    start|stop|restart|kill)
        curl -s -H "Authorization: Bearer $API_KEY" \
            -H "Content-Type: application/json" \
            -X POST -d "{\"signal\":\"$CMD\"}" \
            "$PANEL_URL/api/client/servers/$SERVER/power"
        echo "$CMD server $SERVER"
        ;;
    cmd)
        shift
        COMMAND="$*"
        curl -s -H "Authorization: Bearer $API_KEY" \
            -H "Content-Type: application/json" \
            -X POST -d "{\"command\":\"$COMMAND\"}" \
            "$PANEL_URL/api/client/servers/$SERVER/command"
        echo "Sent: $COMMAND"
        ;;
    upload)
        shift
        FILE="$1"
        shift || true

        DIR_FLAG=""
        POSITIONAL_DIR=""

        while [ "$#" -gt 0 ]; do
            case "$1" in
                -d|--dir)
                    shift
                    if [ -z "${1:-}" ]; then
                        echo "Error: --dir requires a value"
                        exit 1
                    fi
                    DIR_FLAG="$1"
                    ;;
                *)
                    if [ -z "$POSITIONAL_DIR" ]; then
                        POSITIONAL_DIR="$1"
                    fi
                    ;;
            esac
            shift || true
        done

        DIR="${DIR_FLAG:-$POSITIONAL_DIR}"

        if [ -z "$DIR" ]; then
            DIR="/plugins"
            echo "Directory not given; defaulting to /plugins. Use --dir to select target directory."
        fi

        if [ -z "$FILE" ] || [ ! -f "$FILE" ]; then
            echo "Error: File not found: $FILE"
            exit 1
        fi

        UPLOAD_URL=$(curl -s -H "Authorization: Bearer $API_KEY" \
            -H "Accept: application/json" \
            "$PANEL_URL/api/client/servers/$SERVER/files/upload?directory=$(python3 -c 'import urllib.parse; print(urllib.parse.quote("'"$DIR"'"))')" | python3 -c "import json,sys; print(json.load(sys.stdin)['attributes']['url'])")

        curl -X POST "$UPLOAD_URL&directory=$(python3 -c 'import urllib.parse; print(urllib.parse.quote("'"$DIR"'"))')" \
            -F "files=@$FILE"
        echo "Uploaded: $FILE to $SERVER/$DIR"
        ;;
    logs)
        curl -s -H "Authorization: Bearer $API_KEY" \
            -H "Content-Type: application/json" \
            "$PANEL_URL/api/client/servers/$SERVER/files/list?directory=/logs" | python3 -c "
import json,sys
data=json.load(sys.stdin)
files=sorted(data['data'], key=lambda x: x['attributes']['modified_at'], reverse=True)
for f in files[:5]:
    a=f['attributes']
    print(a['name'])"
        ;;
    getlog)
        curl -s -H "Authorization: Bearer $API_KEY" \
            -H "Accept: application/octet-stream" \
            "$PANEL_URL/api/client/servers/$SERVER/files/download?file=/logs/latest.log" | python3 -c "
import json,sys,urllib.request
data=json.load(sys.stdin)
url=data['attributes']['url']
print(urllib.request.urlopen(url).read().decode('utf-8'))"
        ;;
    download)
        FILE="$2"
        curl -s -H "Authorization: Bearer $API_KEY" \
            -H "Accept: application/json" \
            "$PANEL_URL/api/client/servers/$SERVER/files/download?file=$FILE" | python3 -c "
import json,sys,urllib.request
data=json.load(sys.stdin)
url=data['attributes']['url']
print(urllib.request.urlopen(url).read().decode('utf-8'))"
        ;;
    servers)
        echo "Available servers:"
        for s in "${SERVER_IDS[@]}"; do
            echo "  $s"
        done
        ;;
    *)
        echo "Usage: $0 [options] <command> [args]"
        echo ""
        echo "Options:"
        echo "  -s <uuid>  Select server (default: $DEFAULT_SERVER)"
        echo ""
        echo "Commands:"
        echo "  servers                - List available servers"
        echo "  status                 - Show server status"
        echo "  start                 - Start server"
        echo "  stop                  - Stop server"
        echo "  restart               - Restart server"
        echo "  cmd <command>          - Run console command"
        echo "  upload <file> [dir]    - Upload file to server"
        echo "  logs                  - List recent log files"
        echo "  getlog                - Get latest.log contents"
        echo ""
        echo "Examples:"
        echo "  $0 -s e8337f4a status      # Check azox server"
        echo "  $0 status                   # Check default server"
        echo "  $0 cmd say hello world       # Run command"
        echo "  $0 upload target/blah.jar /plugins"
        echo "  $0 logs"
        ;;
esac
